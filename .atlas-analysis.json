  "keyFeatures": [
    "Multi-role authentication (Admin, Motel Owner, Customer)",
    "Interactive map-based motel exploration with geolocation",
    "Online room booking and reservation management",
    "Stripe-integrated payment processing",
    "Motel and room management dashboard for owners",
    "Cloudinary-powered image uploads for motel/room galleries",
